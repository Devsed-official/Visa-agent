# ===========================================
# Visa Interview Agent - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# LiveKit Configuration
# -------------------------------------------
# For local development, use the default values below
# For production, use your LiveKit Cloud credentials

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# -------------------------------------------
# Google Gemini API (REQUIRED)
# -------------------------------------------
# Get your API key from: https://aistudio.google.com/apikey
# This key is used for both:
#   - Gemini 2.5 Flash (real-time conversation)
#   - Gemini 2.0 Flash (video analysis)

GOOGLE_API_KEY=your-gemini-api-key-here

# -------------------------------------------
# Optional: Google Cloud (for production)
# -------------------------------------------
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
